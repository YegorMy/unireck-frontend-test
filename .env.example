# Backend API base URL used by the extension's typed client.
# Vite/WXT loads this at build time.
VITE_API_BASE_URL=http://localhost:8000

# Shared secret sent as the `X-API-Key` header on every /v1/briefs/* request.
# Must match the api project's API_API_KEY. Vite/WXT inlines it at build time.
VITE_API_KEY=dev-secret-change-me
